# Production API origin (no trailing slash). Used by `npm run build` via
# .env.production, or set here for a custom build:
# VITE_API_BASE_URL=https://tickets.ouiimi.com
# VITE_API_DOCS_URL=https://tickets.ouiimi.com/api/docs/

# Netlify same-origin proxy (optional — only if you prefer /api proxy over
# VITE_API_BASE_URL). Set in Netlify env vars, not in the browser bundle.
# API_PROXY_TARGET=https://tickets.ouiimi.com
